# PostgreSQL connection string
# Local:   postgresql://postgres:yourpassword@localhost:5432/inventory
# Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/inventory?sslmode=require
# AWS RDS: postgresql://postgres:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/inventory
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/inventory"

# Server port
PORT=8080

# Comma-separated allowed origins. Leave empty to allow all (dev only).
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
