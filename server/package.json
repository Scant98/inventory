{
  "name": "inventory-ws-server",
  "version": "2.0.0",
  "description": "Inventory management server — REST API + WebSocket",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node --transpile-only src/seed.ts",
    "db:setup": "prisma migrate deploy && ts-node --transpile-only src/seed.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "prisma": "^5.22.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
